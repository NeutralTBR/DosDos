module DosDos

import json
import random
import tkinter as tk

fn main() {
    let selectedPerson = open("dosen.json").read()
        |> json.loads()
        |> random.choice()
        
    let finalName = selectedPerson["n_OFFICIAL_NM"]

    let root = tk.Tk()
    root.title("Random Dosen Selector")
    root.geometry("400x150")

    let label = tk.Label(root)
    label["text"] = finalName
    label.pack()

    root.mainloop()
}